{
    "name": "@montferret/ferret-wasm",
    "version": "2.0.0-alpha.30",
    "description": "Ferret v2 compiler and runtime for WebAssembly",
    "type": "module",
    "main": "./dist/index.node.cjs",
    "module": "./dist/index.node.js",
    "types": "./dist/index.node.d.ts",
    "exports": {
        ".": {
            "browser": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "default": "./dist/index.js"
            },
            "types": "./dist/index.node.d.ts",
            "import": "./dist/index.node.js",
            "require": "./dist/index.node.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "make build",
        "build:js": "tsup",
        "build:wasm": "make wasm",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:browser": "playwright test",
        "test:go": "make test-go",
        "check": "npm run typecheck && npm run format:check && npm run test && npm run test:go",
        "format": "prettier --write \"js/**/*.ts\" \"test/**/*.{ts,mjs}\" \"*.{ts,json,md,yml}\" \".github/**/*.yml\" && gofmt -w main.go ferret",
        "format:check": "prettier --check \"js/**/*.ts\" \"test/**/*.{ts,mjs}\" \"*.{ts,json,md,yml}\" \".github/**/*.yml\"",
        "pack:check": "npm pack --dry-run --cache .cache/npm",
        "prepublishOnly": "npm run build && npm run check && npm run pack:check"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MontFerret/ferret-wasm.git"
    },
    "keywords": [
        "ferret",
        "fql",
        "runtime",
        "compiler",
        "wasm",
        "webassembly",
        "browser"
    ],
    "author": "MontFerret Team",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/MontFerret/ferret-wasm/issues"
    },
    "homepage": "https://github.com/MontFerret/ferret-wasm#readme",
    "engines": {
        "node": ">=22"
    },
    "devDependencies": {
        "@playwright/test": "^1.55.0",
        "@types/node": "^24.0.0",
        "prettier": "^3.6.0",
        "tsup": "^8.5.0",
        "typescript": "^5.9.0",
        "vitest": "^3.2.0"
    }
}
